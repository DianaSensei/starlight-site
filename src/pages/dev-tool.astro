---

<Layout
  title="DevTool — Offline developer utilities"
  description="DevTool packs a growing collection of offline developer utilities into one fast, clean desktop app. No network, no telemetry, no accounts."
>
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-4 pt-12 pb-10 text-center">
    <div class="flex justify-center mb-4">
      <DevToolLogo size={56} class="rounded-2xl shadow-lg shadow-blue-900/20" />
    </div>

    <div class="inline-flex items-center gap-2 text-xs font-medium text-brand-600 dark:text-brand-400 bg-brand-50 dark:bg-brand-900/30 border border-brand-200 dark:border-brand-800 px-3 py-1.5 rounded-full mb-4">
      <span class="w-1.5 h-1.5 rounded-full bg-brand-500 animate-pulse"></span>
      <span id="hero-version" class="opacity-0 transition-opacity duration-200"></span> · MIT License
    </div>

    <h1 class="text-3xl sm:text-4xl font-medium text-slate-900 dark:text-white mb-3 leading-tight">
      Offline developer utilities. One fast, clean app.
    </h1>

    <p class="text-base text-slate-600 dark:text-slate-400 max-w-xl mx-auto mb-6 leading-relaxed">
      Text processing, encoding, hashing, formatting, and more — most run fully offline.
      No telemetry, no accounts, no tracking.
    </p>

    <div class="flex flex-wrap gap-3 justify-center mb-3">
      <a
        id="download-btn"
        href="https://github.com/DianaSensei/developer-desktop-utils/releases/latest"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-brand-600 hover:bg-brand-700 text-white font-medium text-sm transition-colors"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download <span id="download-label" class="opacity-0 transition-opacity duration-200"></span>
      </a>
      <a
        href="https://github.com/DianaSensei/developer-desktop-utils"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 font-medium text-sm transition-colors"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        View on GitHub
      </a>
    </div>

    <p class="text-xs text-slate-400 dark:text-slate-500">macOS · Windows · Linux</p>
  </section>

  <!-- Features -->
  <section class="max-w-5xl mx-auto px-4 pb-10">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-3">Why DevTool</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-2.5">
      {features.map(f => (
        <div class="flex gap-2.5 p-3 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/30">
          <svg class="w-4 h-4 text-brand-500 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          <div>
            <p class="text-sm font-medium text-slate-900 dark:text-white mb-0.5">{f.label}</p>
            <p class="text-xs text-slate-500 dark:text-slate-400 leading-snug">{f.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Tools -->
  <section class="max-w-5xl mx-auto px-4 pb-10">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-3">Tools</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-2.5">
      {tools.map(tool => (
        <div class="border border-slate-200 dark:border-slate-800 rounded-lg p-3 hover:border-slate-300 dark:hover:border-slate-700 transition-colors bg-white dark:bg-slate-900/30">
          <div class="flex items-center gap-2.5 mb-1.5">
            <span class="w-8 h-8 shrink-0 flex items-center justify-center rounded-lg border bg-card border-slate-200 dark:border-slate-800">
              <svg class="w-4 h-4 text-brand-600 dark:text-brand-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={tool.icon} />
            </span>
            <p class="text-sm font-medium text-slate-900 dark:text-white leading-tight">{tool.name}</p>
          </div>
          <p class="text-xs text-slate-500 dark:text-slate-400 leading-snug">{tool.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Platform support -->
  <section class="border-y border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50">
    <div class="max-w-5xl mx-auto px-4 py-10">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-4">Platform support</h2>
      <div class="grid sm:grid-cols-3 gap-3 mb-5">
        {platforms.map(p => (
          <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-4 flex items-start gap-3">
            <div class={`w-10 h-10 rounded-xl flex items-center justify-center shrink-0 ${p.bg}`}>
              <svg viewBox="0 0 24 24" fill="currentColor" class={`w-5 h-5 ${p.iconClass}`}>
                <path d={p.iconPath} />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-medium text-slate-900 dark:text-white leading-tight">{p.name}</p>
              <p class="text-xs text-slate-400 dark:text-slate-500 mb-1">{p.versions} · <span class="font-mono">{p.format}</span></p>
              <div id={`dl-${p.id}`} class="flex flex-wrap gap-1.5 mt-2"></div>
            </div>
          </div>
        ))}
      </div>

      <div class="p-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800/50 rounded-xl text-sm text-amber-800 dark:text-amber-300">
        <p class="font-medium mb-1">macOS — app not yet notarized</p>
        <p class="text-amber-700 dark:text-amber-400 mb-2 text-sm leading-relaxed">
          macOS Gatekeeper may block the app on first launch because it isn't signed with an Apple notarization certificate.
          To allow it, move the app to <code class="font-mono text-xs bg-amber-100 dark:bg-amber-900/40 px-1 py-0.5 rounded">/Applications</code> first, then run this command once in Terminal:
        </p>
        <code class="block font-mono text-xs bg-amber-100 dark:bg-amber-900/40 px-4 py-2.5 rounded-lg">xattr -cr /Applications/DevTool.app</code>
      </div>
    </div>
  </section>

  <!-- Download CTA -->
  <section class="max-w-5xl mx-auto px-4 py-12 text-center">
    <h2 class="text-2xl font-medium text-slate-900 dark:text-white mb-2">Ready to try it?</h2>
    <p class="text-slate-500 dark:text-slate-400 mb-5 text-sm">Free, open source, and runs entirely on your machine.</p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a
        id="cta-download-btn"
        href="https://github.com/DianaSensei/developer-desktop-utils/releases/latest"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-brand-600 hover:bg-brand-700 text-white font-medium text-sm transition-colors"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download <span id="cta-download-label" class="opacity-0 transition-opacity duration-200"></span>
      </a>
      <a
        href="https://github.com/DianaSensei/developer-desktop-utils/releases"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 font-medium text-sm transition-colors"
      >
        All releases →
      </a>
    </div>
  </section>
</Layout>

<script>
  const REPO = 'DianaSensei/developer-desktop-utils';
  const RAW = `https://raw.githubusercontent.com/${REPO}/main/src-tauri/tauri.conf.json`;
  const DL_BASE = `https://github.com/${REPO}/releases/download`;

  const dlIcon = `<svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`;
  const btnClass = 'inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors';

  function detectPlatform(): 'macos' | 'windows' | 'linux' | null {
    const ua = navigator.userAgent;
    if (/Mac/i.test(ua) && !/iPhone|iPad/i.test(ua)) return 'macos';
    if (/Win/i.test(ua)) return 'windows';
    if (/Linux/i.test(ua)) return 'linux';
    return null;
  }

  function addBtn(containerId: string, label: string, url: string) {
    const container = document.getElementById(containerId);
    if (!container) return;
    const a = document.createElement('a');
    a.href = url;
    a.className = btnClass;
    a.innerHTML = `${dlIcon}<span>${label}</span>`;
    container.appendChild(a);
  }

  (async () => {
    try {
      const res = await fetch(RAW);
      if (!res.ok) return;
      const { version, productName } = await res.json();
      if (!version || !productName) return;

      const tag = `v${version}`;
      const base = `${DL_BASE}/${tag}/${productName}_${version}`;

      // Show version badge in hero chip
      const heroVer = document.getElementById('hero-version');
      if (heroVer) { heroVer.textContent = tag; heroVer.classList.remove('opacity-0'); }

      // Detect platform and wire the primary download buttons
      const platform = detectPlatform();
      const platformMap: Record<string, { name: string; url: string }> = {
        macos:   { name: 'macOS',   url: `${base}_aarch64.dmg` },
        windows: { name: 'Windows', url: `${base}_x64-setup.exe` },
        linux:   { name: 'Linux',   url: `${base}_amd64.AppImage` },
      };

      const detected = platform ? platformMap[platform] : null;
      const primaryUrl = detected ? detected.url : `https://github.com/${REPO}/releases/tag/${tag}`;
      const primaryLabel = detected
        ? `${tag} for ${detected.name}`
        : `${tag}`;

      for (const [btnId, labelId] of [['download-btn', 'download-label'], ['cta-download-btn', 'cta-download-label']]) {
        const btn = document.getElementById(btnId) as HTMLAnchorElement | null;
        const lbl = document.getElementById(labelId);
        if (btn) btn.href = primaryUrl;
        if (lbl) { lbl.textContent = primaryLabel; lbl.classList.remove('opacity-0'); }
      }

      // Platform section: per-OS download buttons
      addBtn('dl-macos',   '.dmg',        `${base}_aarch64.dmg`);
      addBtn('dl-windows', '.msi',        `${base}_x64_en-US.msi`);
      addBtn('dl-windows', '.exe (NSIS)', `${base}_x64-setup.exe`);
      addBtn('dl-linux',   '.AppImage',   `${base}_amd64.AppImage`);
      addBtn('dl-linux',   '.deb',        `${base}_amd64.deb`);
    } catch (e) {
      console.warn('[DevTool]', e);
    }
  })();
</script>
