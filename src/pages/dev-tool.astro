  {
    id: 'windows',
    name: 'Windows',
    versions: '10 / 11',
    format: '.msi · .exe (NSIS)',
    // Windows logo — 4-pane flag (MDI)
    iconPath: 'M3,12V6.75L9,5.43V11.91L3,12M20,3V11.75L11,10.9V5.21L20,3M3,13L9,13.09V19.9L3,18.75V13M20,13.25V22L11,20.84V13.1L20,13.25Z',
    bg: 'bg-blue-50 dark:bg-blue-900/30',
    iconClass: 'text-blue-600 dark:text-blue-400',
  },
  {
    id: 'linux',
    name: 'Linux',
    versions: 'Ubuntu 22.04+',
    format: '.AppImage · .deb',
    // Tux penguin (MDI)
    iconPath: 'M14.62,8.35C14.2,8.63 13.33,9.32 13.13,9.57C12.93,9.82 13.2,10.26 13.33,10.43C13.55,10.72 13.87,11.25 14.54,11.67C14.62,11.72 14.71,11.76 14.81,11.77C14.97,11.78 15.08,11.72 15.17,11.67C15.84,11.25 16.16,10.72 16.38,10.43C16.51,10.26 16.78,9.82 16.58,9.57C16.38,9.32 15.51,8.63 15.09,8.35C14.97,8.27 14.85,8.23 14.73,8.23C14.62,8.23 14.5,8.27 14.38,8.35M10.09,8.35L9.58,8.35C9.19,8.27 9.08,8.23 8.96,8.23C8.85,8.23 8.72,8.27 8.61,8.35C8.19,8.63 7.32,9.32 7.12,9.57C6.92,9.82 7.19,10.26 7.32,10.43C7.54,10.72 7.86,11.25 8.53,11.67C8.62,11.72 8.73,11.76 8.83,11.77C8.99,11.78 9.1,11.72 9.19,11.67C9.86,11.25 10.18,10.72 10.4,10.43C10.53,10.26 10.8,9.82 10.6,9.57C10.4,9.32 9.53,8.63 9.11,8.35H10.09M12,2A5,5 0 0,0 7,7C7,8.42 7.58,9.71 8.5,10.65V13H7A2,2 0 0,0 5,15V16H4A1,1 0 0,0 3,17V19A1,1 0 0,0 4,20H20A1,1 0 0,0 21,19V17A1,1 0 0,0 20,16H19V15A2,2 0 0,0 17,13H15.5V10.65C16.42,9.71 17,8.42 17,7A5,5 0 0,0 12,2M15.5,15V18H8.5V15H15.5Z',
    bg: 'bg-yellow-50 dark:bg-yellow-900/20',
    iconClass: 'text-yellow-600 dark:text-yellow-400',
  },
