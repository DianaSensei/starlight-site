const features = [
  { label: 'Offline first', desc: 'Most tools run fully offline. The only network traffic is lookups you trigger yourself.' },
  { label: 'No accounts', desc: 'Open the app and use it. Nothing to sign up for.' },
  { label: 'No telemetry', desc: 'Zero tracking, analytics, or crash reporting.' },
  { label: 'Fast & lightweight', desc: 'Native desktop app — instant launch, low memory.' },
  { label: 'MIT licensed', desc: 'Open source. Audit it, fork it, ship it.' },
  { label: 'Always improving', desc: 'Each release ships patch fixes, UI/UX improvements, and new features and utilities.' },
  { label: 'Built-in updates', desc: 'Checks for new versions on launch and installs them in one click — no need to revisit this site or re-download.' },
  { label: 'Your feedback counts', desc: 'Report bugs, request features, and contribute on GitHub — straight from the app.' },
];

const platforms = [
  {
    id: 'macos',
    name: 'macOS',
    versions: '11 (Big Sur)+',
    format: '.dmg · Apple Silicon',
    // Apple logo (MDI)
    iconPath: 'M18.71,19.5C17.88,20.74 17,21.95 15.66,21.97C14.32,22 13.89,21.18 12.37,21.18C10.84,21.18 10.37,21.95 9.1,22C7.78,22.05 6.8,20.68 5.96,19.47C4.25,17 2.94,12.45 4.7,9.39C5.57,7.87 7.13,6.91 8.82,6.88C10.1,6.86 11.32,7.75 12.11,7.75C12.89,7.75 14.37,6.68 15.91,6.84C16.57,6.87 18.39,7.1 19.56,8.82C19.47,8.88 17.39,10.1 17.41,12.63C17.44,15.65 20.06,16.66 20.09,16.67C20.06,16.74 19.67,18.11 18.71,19.5M13,3.5C13.73,2.67 14.94,2.04 15.94,2C16.07,3.17 15.6,4.35 14.9,5.19C14.21,6.04 13.07,6.7 11.95,6.61C11.8,5.46 12.36,4.26 13,3.5Z',
    bg: 'bg-slate-100 dark:bg-slate-800',
    iconClass: 'text-slate-700 dark:text-slate-200',
