---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
---

<Layout
  title="Home — Developer & Maker"
  description="Developer passionate about open source, scalable systems, and building tools that run offline with zero compromise."
>
  <!-- Welcome -->
  <section class="max-w-3xl mx-auto px-4 pt-20 pb-12">
    <p id="greeting" class="text-sm text-slate-500 dark:text-slate-400 font-mono mb-5"></p>
    <h1 class="text-4xl sm:text-5xl font-medium text-slate-900 dark:text-white mb-4 leading-tight">
      Welcome to my space.
    </h1>
    <p class="text-slate-500 dark:text-slate-400 leading-relaxed">
      I build open-source tools and write about software engineering.
    </p>
  </section>

  <!-- Projects -->
  <section class="max-w-3xl mx-auto px-4 pb-16">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-6">Projects</h2>
    <a
      href={`${base}/dev-tool`}
      class="group block border border-slate-200 dark:border-slate-800 rounded-2xl p-6 hover:border-brand-300 dark:hover:border-brand-700 hover:bg-brand-50/30 dark:hover:bg-brand-900/10 transition-all"
    >
      <div class="flex items-start justify-between gap-4 mb-4">
        <div class="flex items-center gap-4">
          <div class="w-11 h-11 rounded-xl bg-brand-100 dark:bg-brand-900/40 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-brand-600 dark:text-brand-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
            </svg>
          </div>
          <div>
            <div class="flex items-baseline gap-3">
              <p class="text-xl font-semibold text-slate-900 dark:text-white">DevTool</p>
              <span id="project-version" class="text-sm text-brand-600 dark:text-brand-400 font-mono opacity-0 transition-opacity duration-200"></span>
            </div>
            <p class="text-xs text-slate-400 dark:text-slate-500 mt-0.5">Desktop app · macOS · Windows · Linux</p>
          </div>
        </div>
        <svg class="w-4 h-4 text-slate-400 group-hover:text-brand-500 transition-colors mt-1 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </div>
      <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-4">
        A growing collection of offline developer utilities in one fast, clean desktop app —
        text processing, encoding, JWT debugger, color tools, and more.
        Runs entirely locally with no network, no telemetry, and no accounts required.
      </p>
      <div class="flex flex-wrap gap-2">
        {['MIT', 'open source', 'offline'].map(t => (
          <span class="text-xs px-2 py-0.5 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400">{t}</span>
        ))}
      </div>
    </a>
  </section>

  <!-- Blog -->
  <section class="max-w-3xl mx-auto px-4 pb-16">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500">Latest posts</h2>
      <a href={`${base}/blog`} class="text-xs text-brand-600 dark:text-brand-400 hover:underline">All posts →</a>
    </div>
    <div class="border border-slate-200 dark:border-slate-800 rounded-2xl p-6">
      <p class="text-sm text-slate-400 dark:text-slate-500">No posts yet — check back soon.</p>
    </div>
  </section>

  <!-- About -->
  <section class="max-w-3xl mx-auto px-4 pb-20">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-6">About</h2>
    <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
      Passionate about open source and engineering software that lasts.
      I design systems with scalability, high availability, and fault tolerance as first-class concerns —
      grounded in solid OOP, proven design patterns, and zero-trust principles.
      Everything I build aims to be trusted, resilient, and maintainable at any scale.
    </p>
  </section>
</Layout>

<script>
  // Time-based greeting
  const hour = new Date().getHours();
  const greeting = hour < 12 ? 'Good morning' : hour < 18 ? 'Good afternoon' : 'Good evening';
  const el = document.getElementById('greeting');
  if (el) el.textContent = greeting + '.';

  // Version
  (async () => {
    try {
      const res = await fetch('https://raw.githubusercontent.com/DianaSensei/developer-desktop-utils/main/src-tauri/tauri.conf.json');
      if (!res.ok) return;
      const { version } = await res.json();
      if (!version) return;
      const el = document.getElementById('project-version');
      if (el) { el.textContent = `v${version}`; el.classList.remove('opacity-0'); }
    } catch {}
  })();
</script>
